generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  username    String    @unique
  password    String
  displayName String    @default("") @map("display_name")
  avatar      String    @default("")
  bio         String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastActive  DateTime  @default(now()) @map("last_active")

  companions     Companion[]
  messages       Message[]
  proactiveQueue ProactiveQueue[]

  @@map("users")
}

model Companion {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  personality  String   @default("ami")
  avatar      String   @default("")
  description String   @default("")
  greeting    String   @default("Salut ! Comment ca va ?")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
  proactiveQueue ProactiveQueue[]

  @@map("companions")
}

model Message {
  id          String   @id @default(cuid())
  companionId String   @map("companion_id")
  userId      String   @map("user_id")
  content     String
  sender      String   @default("user")
  createdAt   DateTime @default(now()) @map("created_at")

  companion Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companionId, createdAt])
  @@index([userId])
  @@map("messages")
}

model ProactiveQueue {
  id          String   @id @default(cuid())
  companionId String   @map("companion_id")
  userId      String   @map("user_id")
  message     String
  scheduledAt DateTime @map("scheduled_at")
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  companion Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sent, scheduledAt])
  @@map("proactive_queue")
}
